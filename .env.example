# Public site URL used for canonical metadata, sitemap generation, and same-origin checks.
# Configure Production, Preview, and Development values in Vercel as appropriate.
SITE_URL=https://www.example.com

# Contact details displayed on the website.
CONTACT_EMAIL=info@example.com
CONTACT_PHONE=+254700000000

# Server-side email configuration.
MAIL_PROVIDER=log
MAIL_FROM=no-reply@example.com
MAIL_TO=info@example.com

# Example provider placeholders. Configure only the provider you actually use.
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_SECURE=false
